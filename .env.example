# ============================================
# FOOD DELIVERY PLATFORM - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# REQUIRED (Must be set)
# ============================================

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=10000
NODE_ENV=production

# ============================================
# OPTIONAL - MESSAGE QUEUE (RabbitMQ)
# ============================================
# Get free instance: https://customer.cloudamqp.com
# Enables: Event-driven architecture, async notifications
RABBITMQ_URL=amqps://khfkynkj:3Qr2oS_S-Y8k3-DjAvE7_N3b_GBLQT_b@chameleon.lmq.cloudamqp.com/khfkynkj

# ============================================
# OPTIONAL - CACHE (Redis)
# ============================================
# Get free instance: https://upstash.com
# Enables: Response caching, faster API calls
REDIS_URL=redis://default:gQAAAAAAAbbpAAIgcDE0ODYwNWFhMDMyMmY0NDYzOGEzOTlkZTdiODEwMDI4NQ@sacred-tetra-112361.upstash.io:6379

# ============================================
# OPTIONAL - SERVICE DISCOVERY (Consul)
# ============================================
# Get free instance: https://portal.cloud.hashicorp.com
# Enables: Dynamic service discovery, health checks
CONSUL_HOST=https://your-cluster.consul.hashicorp.cloud
CONSUL_TOKEN=your-consul-token

# ============================================
# OPTIONAL - MONITORING (Grafana Cloud)
# ============================================
# Get free account: https://grafana.com
# Enables: Metrics, dashboards, alerts
GRAFANA_CLOUD_URL=https://prometheus-prod-01-eu-west-0.grafana.net/api/prom/push
GRAFANA_CLOUD_API_KEY=your-api-key
GRAFANA_CLOUD_USER=your-user-id

# ============================================
# OPTIONAL - TRACING (Jaeger)
# ============================================
# Enables: Distributed tracing
JAEGER_ENDPOINT=http://localhost:14268/api/traces
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ============================================
# OPTIONAL - LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# OPTIONAL - CORS
# ============================================
CORS_ORIGIN=https://fooddelevryapp.vercel.app

# ============================================
# OPTIONAL - RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# OPTIONAL - EMAIL (SendGrid)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@fooddelivery.com

# ============================================
# OPTIONAL - SMS (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# OPTIONAL - PAYMENT (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# OPTIONAL - STORAGE (AWS S3)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=food-delivery-uploads

# ============================================
# LOCAL DEVELOPMENT ONLY
# ============================================
# Use these for local testing with Docker Compose

# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/food_delivery

# Local RabbitMQ
# RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# Local Redis
# REDIS_URL=redis://:redis123@localhost:6379

# Local Consul
# CONSUL_HOST=http://localhost:8500
