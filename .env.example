# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis Configuration
REDIS_URL=redis://default:password@host:6379

# RabbitMQ Configuration
RABBITMQ_URL=amqps://user:password@host/vhost

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Node Environment
NODE_ENV=production

# Service Ports (for local development)
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
RESTAURANT_SERVICE_PORT=3003
MENU_SERVICE_PORT=3004
ORDER_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
DELIVERY_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008

# Frontend API URL (update with your Render backend URL)
VITE_API_URL=https://food-delivery-backend.onrender.com
